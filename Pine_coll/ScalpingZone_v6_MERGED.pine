// ============================================================================
// Scalping Zone Replica (v6) — MERGED Edition  (v3 — all issues resolved)
// ============================================================================
// COMPLETE BUG REGISTRY
// ─────────────────────────────────────────────────────────────────────────────
// BUG-01 [FIXED] longOK/shortOK multi-line ternary → replaced with if/else if
// BUG-02 [FIXED] buyReOK/sellReOK multi-line ternary → replaced with if/else if
// BUG-03 [FIXED] ta.crossover/crossunder inside short-circuit AND expression
//                → pre-computed unconditionally as crossBullRaw/crossBearRaw
// BUG-04 [FIXED] ta.crossover/crossunder in alertcondition args
//                → pre-computed unconditionally as orBreakUp/Down/vwapCrossUp/Dn
// BUG-05 [FIXED] Comma-chained var declarations → one per line
// BUG-06 [FIXED] showBB input missing → added input.bool
// BUG-07 [FIXED] bgCol multi-line ternary inside if block (line ending with :)
//                → rewritten as if/else if block
// BUG-08 [FIXED] barcolor() multi-line nested ternary (line ending with :)
//                → rewritten with explicit if/else if
// BUG-09 [FIXED] rCol multi-line ternary inside if barstate.islast block
//                → rewritten as if/else if
// BUG-10 [FIXED] request.security() called inside ternary conditional
//                → always executed; useHTF gates result via nz() or if/else
// BUG-11 [FIXED] entryEma = ta.ema(close, ma1Len) duplicates ma1 computation
//                → entryEma now reuses ma1 directly (no extra EMA call)
// BUG-12 [FIXED] atrB = ta.atr(bubbleAtrLen) duplicates atrSig later
//                → unified: atrSig declared early, atrB reference replaced
// BUG-13 [NOTE]  f_ma(sessVwap, ..., "VWMA") would pass a non-price/volume
//                series to ta.vwma. VWMA option excluded from mvwapType choices.
// BUG-A  [FIXED] adxCalc() (contains ta.rma) sat in ternary false-branch of
//                adxHTF — may not execute every bar. Pre-computed as _curTFAdx.
// BUG-B  [FIXED] ta.change(time("D")) sat in ternary false-branch of newSess —
//                same risk. Pre-computed as _newDay; plain bool ternary selects.
// ============================================================================

//@version=6
indicator("Scalping Zone Replica v6 — MERGED", overlay=true,
          max_bars_back=2000, max_boxes_count=150, max_labels_count=150, max_lines_count=120)

// ─────────────────────────────────────────────────────────────────────────────
// GROUP 01 — Session + Opening Range
// ─────────────────────────────────────────────────────────────────────────────
grpSess = "01) Session + Opening Range"
useSession   = input.bool(true,          "Use Session Filter",             group=grpSess)
sessionStr   = input.session("0915-1530","Session String",                 group=grpSess)
showSessVWAP = input.bool(true,          "Show Session VWAP",              group=grpSess)
showOR       = input.bool(true,          "Show Opening Range",             group=grpSess)
orMode       = input.string("Manual",    "OR Mode", options=["Auto","Manual"], group=grpSess)
orAutoK      = input.float(3.0,          "OR Auto: K x TF minutes", step=0.5,  group=grpSess)
orMin        = input.int(30,             "OR Manual minutes", minval=1,    group=grpSess)

// ─────────────────────────────────────────────────────────────────────────────
// GROUP 02 — HTF Trend Filter
// ─────────────────────────────────────────────────────────────────────────────
grpTrend    = "02) HTF Trend Filter"
trendMode   = input.string("EMA+ADX","Mode", options=["Off","EMA","EMA+ADX","EMA+Dist"], group=grpTrend)
useHTF      = input.bool(true,       "Use HTF for trend",              group=grpTrend)
tfHTF       = input.timeframe("15",  "HTF Timeframe",                  group=grpTrend)
emaFastLen  = input.int(34,          "HTF EMA Fast",  minval=1,        group=grpTrend)
emaSlowLen  = input.int(89,          "HTF EMA Slow",  minval=2,        group=grpTrend)
adxLen      = input.int(14,          "ADX Length",    minval=1,        group=grpTrend)
adxThr      = input.float(18.0,      "ADX Threshold", step=0.5,        group=grpTrend)
distATRMin  = input.float(0.20,      "EMA Dist min (x ATR)", step=0.01,group=grpTrend)
showCloud   = input.bool(true,       "Show Trend Cloud BG",            group=grpTrend)
plotHTFEMAs = input.bool(false,      "Plot HTF EMAs",                  group=grpTrend)
gateTrend   = input.bool(true,       "Gate TRP1/LVT by Trend",         group=grpTrend)

// ─────────────────────────────────────────────────────────────────────────────
// GROUP 03 — Zones
// ─────────────────────────────────────────────────────────────────────────────
grpZ = "03) Zones (Supply / Demand)"
useTF1 = input.bool(true,  "Use TF1", group=grpZ)
tf1    = input.timeframe("240", "TF1", group=grpZ)
useTF2 = input.bool(true,  "Use TF2", group=grpZ)
tf2    = input.timeframe("D",   "TF2", group=grpZ)
useTF3 = input.bool(false, "Use TF3", group=grpZ)
tf3    = input.timeframe("W",   "TF3", group=grpZ)

pivotL = input.int(3, "Pivot Left",  minval=1, maxval=20, group=grpZ)
pivotR = input.int(3, "Pivot Right", minval=1, maxval=20, group=grpZ)

zoneAtrLen  = input.int(14,    "Zone ATR Length (HTF)", minval=5, maxval=200,            group=grpZ)
zoneAtrMult = input.float(0.5, "Zone Thickness = ATR x", step=0.1, minval=0.1, maxval=5, group=grpZ)

showTargets     = input.bool(true,  "Show Target Zones (prev zone)", group=grpZ)
showZoneLabels  = input.bool(true,  "Show Zone Labels",              group=grpZ)
labelOffsetBars = input.int(30,     "Label X Offset (bars right)",   minval=0, maxval=300, group=grpZ)
showZoneMid     = input.bool(true,  "Show Zone Midline",             group=grpZ)
historyBars     = input.int(800,    "Zone History (bars left)",  minval=0,  maxval=10000,  group=grpZ)
maxLeftOffset   = input.int(2000,   "Max Left Offset Clamp (bars)", minval=100, maxval=5000, group=grpZ)
extendRightBars = input.int(400,    "Zone Extend (bars right)", minval=20, maxval=10000,   group=grpZ)
padTicks        = input.int(10,     "Zone Pad (ticks)",          minval=0,  maxval=200,    group=grpZ)
dimInvalidated  = input.bool(true,  "Dim Invalidated Zones",                              group=grpZ)
showConfluentHL = input.bool(true,  "Highlight Confluent Zones (2+ TF)",                  group=grpZ)

// ─────────────────────────────────────────────────────────────────────────────
// GROUP 04 — Operator Candles + Activity
// ─────────────────────────────────────────────────────────────────────────────
grpO = "04) Operator Candles + Activity"
paintOperatorCandles = input.bool(true,  "Paint Operator Candles (Blue/Black)", group=grpO)
opVolLen             = input.int(20,     "Volume SMA Length",  minval=5, maxval=200, group=grpO)
opVolMult            = input.float(2.0,  "Operator Vol Mult",  step=0.1,             group=grpO)
showBubbles          = input.bool(true,  "Show Volume Bubbles",                      group=grpO)
bubbleAtrLen         = input.int(14,     "Bubble ATR Length", minval=5, maxval=200,  group=grpO)
bubbleAtrMult        = input.float(0.9,  "Bubble Body > ATR x", step=0.1,            group=grpO)
bubbleVolMult        = input.float(2.2,  "Bubble Vol > SMA x",  step=0.1,            group=grpO)
bubbleOnlyInZone     = input.bool(true,  "Bubble only when in zone",                 group=grpO)

// BUG-13: VWMA excluded from mvwapType — ta.vwma requires a price series + volume,
// but sessVwap is already a price average. Passing it to ta.vwma produces garbage.
deltaMode    = input.string("RangeWeighted", "Delta Proxy",
               options=["RangeWeighted","CloseVsPrev","CloseVsOpen"],  group=grpO)
activityMode = input.string("Off", "Density Boxes Mode",
               options=["Off","Densities"],                             group=grpO)
denMetricSrc = input.string("AbsDelta", "Density Metric",
               options=["AbsDelta","Volume"],                           group=grpO)
qLen         = input.int(200,  "Quantile Lookback", minval=50,         group=grpO)
qPct         = input.float(92, "Quantile %", step=0.5, minval=60, maxval=99.9, group=grpO)
denDepth     = input.float(0.45,"Density Depth x ATR", step=0.05,      group=grpO)
denExtend    = input.int(150,  "Density Extend (bars)", minval=10,      group=grpO)
mergeX       = input.float(0.30,"Merge if |delta| < x ATR", step=0.05, group=grpO)
volLen       = input.int(20,   "Volume MA (density break)",             group=grpO)
breakMult    = input.float(1.2,"Delete if break vol > MA x", step=0.1, group=grpO)
maxDenBoxes  = input.int(20,   "Max Density Boxes", minval=5, maxval=60,group=grpO)

// ─────────────────────────────────────────────────────────────────────────────
// GROUP 05 — Overlays
// ─────────────────────────────────────────────────────────────────────────────
grpOv = "05) Overlays (MVWAP / MAs / Bands / ST / RSI)"
// BUG-13 fix: VWMA excluded from MVWAP type options
showMVWAP = input.bool(true,   "Show MVWAP (MA of Session VWAP)",          group=grpOv)
mvwapLen  = input.int(50,      "MVWAP Length", minval=5, maxval=500,        group=grpOv)
mvwapType = input.string("SMA","MVWAP Type", options=["SMA","EMA","RMA","WMA"], group=grpOv)

showMA1 = input.bool(true,    "Show MA1",                                   group=grpOv)
ma1Len  = input.int(20,       "MA1 Length", minval=1, maxval=500,           group=grpOv)
ma1Type = input.string("EMA", "MA1 Type", options=["SMA","EMA","RMA","WMA","VWMA"], group=grpOv)
showMA2 = input.bool(true,    "Show MA2",                                   group=grpOv)
ma2Len  = input.int(50,       "MA2 Length", minval=1, maxval=500,           group=grpOv)
ma2Type = input.string("EMA", "MA2 Type", options=["SMA","EMA","RMA","WMA","VWMA"], group=grpOv)
showMA3 = input.bool(false,   "Show MA3",                                   group=grpOv)
ma3Len  = input.int(200,      "MA3 Length", minval=1, maxval=1000,          group=grpOv)
ma3Type = input.string("EMA", "MA3 Type", options=["SMA","EMA","RMA","WMA","VWMA"], group=grpOv)

showMACross = input.bool(true, "Show MA1/MA2 Cross Signal",                 group=grpOv)

showHTFMA        = input.bool(false,  "Show HTF MA",                        group=grpOv)
htfMA_tf         = input.timeframe("240","HTF MA Timeframe",                group=grpOv)
htfMA_len        = input.int(50,      "HTF MA Length", minval=1, maxval=500,group=grpOv)
htfMA_type       = input.string("EMA","HTF MA Type", options=["SMA","EMA","RMA","WMA","VWMA"], group=grpOv)
htfConfirmedOnly = input.bool(true,   "HTF MA Confirmed Bars Only",         group=grpOv)

// BUG-06 FIX: showBB was undeclared in previous version
showBB     = input.bool(true,  "Show Bollinger Bands",                      group=grpOv)
bbLen      = input.int(20,     "BB Length", minval=5, maxval=200,           group=grpOv)
bbMult     = input.float(2.0,  "BB StDev",  step=0.1,                      group=grpOv)
showBBFill = input.bool(true,  "Show BB Fill",                              group=grpOv)

showST1 = input.bool(true,  "Show Supertrend 1",                            group=grpOv)
st1Atr  = input.int(10,     "ST1 ATR Len", minval=1, maxval=200,            group=grpOv)
st1Mult = input.float(3.0,  "ST1 Mult", step=0.1,                          group=grpOv)
showST2 = input.bool(false, "Show Supertrend 2",                            group=grpOv)
st2Atr  = input.int(21,     "ST2 ATR Len", minval=1, maxval=200,            group=grpOv)
st2Mult = input.float(2.0,  "ST2 Mult", step=0.1,                          group=grpOv)

showRSILast = input.bool(true, "Show RSI last value label",                 group=grpOv)
rsiLen      = input.int(14,    "RSI Length", minval=2, maxval=200,          group=grpOv)
showRSIBg   = input.bool(true, "RSI OB/OS Background",                      group=grpOv)
rsiOB       = input.int(70,    "RSI Overbought Level", minval=50, maxval=95, group=grpOv)
rsiOS       = input.int(30,    "RSI Oversold Level",   minval=5,  maxval=50, group=grpOv)

// ─────────────────────────────────────────────────────────────────────────────
// GROUP 06 — Scalping Signals
// ─────────────────────────────────────────────────────────────────────────────
grpS = "06) Scalping Signals (TRP1 / LVT)"
showSignals   = input.bool(true,  "Show Scalping Signals",                   group=grpS)
showDirLabels = input.bool(true,  "Show LONG / SHORT Labels",                group=grpS)
trapVolMult   = input.float(1.8,  "TRP1 Vol Mult (vs SMA)",   step=0.1,      group=grpS)
lvtVolMaxMult = input.float(0.9,  "LVT Max Vol Mult (vs SMA)",step=0.1,      group=grpS)
lvtBodyMaxAtr = input.float(0.6,  "LVT Body Max ATR x",       step=0.1,      group=grpS)
minBodyATR    = input.float(0.30, "Min Body (x ATR) for Signal", step=0.01,  group=grpS)
wickMaxPct    = input.float(0.55, "Max Opposite Wick (0..1)", step=0.05, minval=0.0, maxval=1.0, group=grpS)
gateVWAP      = input.bool(true,  "Gate by Session VWAP (long above, short below)", group=grpS)

showSigLabels  = input.bool(true,  "Show SL / TP Label on Signal",          group=grpS)
keepLatestSigLabel = input.bool(true, "Keep Only Latest SL/TP Label (per side)", group=grpS)
sigStopMult    = input.float(1.0,  "Stop Loss ATR Mult",    step=0.1,        group=grpS)
sigTarget1Mult = input.float(1.5,  "Take Profit 1 ATR Mult",step=0.1,        group=grpS)
sigTarget2Mult = input.float(3.0,  "Take Profit 2 ATR Mult",step=0.1,        group=grpS)

reMode          = input.string("MoveAway+Retest","Re-entry Mode",
                  options=["Cooldown","MoveAway+Retest","Either"],            group=grpS)
sigCooldownBars = input.int(5,     "Cooldown Bars",   minval=1, maxval=50,   group=grpS)
resetMoveATR    = input.float(0.60,"Move-Away Reset (x ATR)", step=0.05,     group=grpS)

// ─────────────────────────────────────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────────────────────────────────────
tf_minutes() =>
    float m = na
    if timeframe.isseconds
        m := math.max(1.0, timeframe.multiplier) / 60.0
    else if timeframe.isminutes
        m := float(timeframe.multiplier)
    else if timeframe.isdaily
        m := 1440.0 * timeframe.multiplier
    else if timeframe.isweekly
        m := 10080.0 * timeframe.multiplier
    else
        m := 43200.0 * timeframe.multiplier
    m

adxCalc(_len) =>
    float upMove  = high - high[1]
    float dnMove  = low[1] - low
    float plusDM  = (upMove > dnMove and upMove > 0) ? upMove : 0.0
    float minusDM = (dnMove > upMove and dnMove > 0) ? dnMove : 0.0
    float tr      = math.max(high - low,
                    math.max(math.abs(high - close[1]), math.abs(low - close[1])))
    float smTR    = ta.rma(tr, _len)
    float smP     = ta.rma(plusDM, _len)
    float smM     = ta.rma(minusDM, _len)
    float pDI     = smTR != 0 ? 100.0 * smP / smTR : 0.0
    float mDI     = smTR != 0 ? 100.0 * smM / smTR : 0.0
    float dx      = (pDI + mDI != 0) ? 100.0 * math.abs(pDI - mDI) / (pDI + mDI) : 0.0
    ta.rma(dx, _len)

f_ma(src, len, typ) =>
    float out = na
    if typ == "SMA"
        out := ta.sma(src, len)
    else if typ == "EMA"
        out := ta.ema(src, len)
    else if typ == "RMA"
        out := ta.rma(src, len)
    else if typ == "WMA"
        out := ta.wma(src, len)
    else if typ == "VWMA"
        out := ta.vwma(src, len)
    else
        out := ta.sma(src, len)
    out

pad = syminfo.mintick * padTicks

f_touchZone(top, bot) =>
    bool result = false
    if not na(top) and not na(bot)
        float t = math.max(top, bot)
        float b = math.min(top, bot)
        result := (high >= b - pad) and (low <= t + pad)
    result

f_trapSell(supTop, supBot, volSma) =>
    float t = math.max(supTop, supBot)
    (high > t + pad) and (close < t) and (volume > volSma * trapVolMult) and (close < open)

f_trapBuy(demTop, demBot, volSma) =>
    float b = math.min(demTop, demBot)
    (low < b - pad) and (close > b) and (volume > volSma * trapVolMult) and (close > open)

f_lvtBuy(demTop, demBot, volSma, atr) =>
    float t  = math.max(demTop, demBot)
    float b  = math.min(demTop, demBot)
    float bd = math.abs(close - open)
    (low <= t + pad) and (low >= b - 2 * pad) and (close > t) and
     (volume < volSma * lvtVolMaxMult) and (bd < atr * lvtBodyMaxAtr)

f_lvtSell(supTop, supBot, volSma, atr) =>
    float t  = math.max(supTop, supBot)
    float b  = math.min(supTop, supBot)
    float bd = math.abs(close - open)
    (high >= b - pad) and (high <= t + 2 * pad) and (close < b) and
     (volume < volSma * lvtVolMaxMult) and (bd < atr * lvtBodyMaxAtr)

f_anyTF3(use1, use2, use3, sig1, sig2, sig3) =>
    (use1 and sig1) or (use2 and sig2) or (use3 and sig3)

f_safeLeft(int idx) =>
    int lookback = math.min(historyBars, maxLeftOffset)
    math.max(0, idx - lookback)

f_liveLeft(int storedLeft) =>
    int minLeftNow = f_safeLeft(bar_index)
    na(storedLeft) ? minLeftNow : math.max(storedLeft, minLeftNow)

f_box_update(box bIn, bool enabled, int left, float top, float bot, color bg, color brd) =>
    box b = bIn
    color hideCol = color.new(color.gray, 100)
    if enabled and not na(top) and not na(bot)
        float t  = math.max(top, bot)
        float bt = math.min(top, bot)
        int leftNow = math.max(left, f_safeLeft(bar_index))
        if na(b)
            b := box.new(leftNow, t, bar_index + extendRightBars, bt, bgcolor=bg, border_color=brd)
        else
            box.set_left(b, leftNow)
            box.set_right(b, bar_index + extendRightBars)
            box.set_top(b, t)
            box.set_bottom(b, bt)
            box.set_bgcolor(b, bg)
            box.set_border_color(b, brd)
    else
        if not na(b)
            box.set_bgcolor(b, hideCol)
            box.set_border_color(b, hideCol)
    b

f_label_update(label lIn, bool enabled, float y, string txt, color col) =>
    label l = lIn
    int   x = bar_index + labelOffsetBars
    if enabled and not na(y)
        if na(l)
            l := label.new(x, y, txt, style=label.style_label_left, color=col, textcolor=color.white)
        else
            label.set_xy(l, x, y)
            label.set_text(l, txt)
            label.set_color(l, col)
            label.set_textcolor(l, color.white)
    else
        if not na(l)
            label.delete(l)
        l := na
    l

f_supBg(inv) =>
    (dimInvalidated and inv) ? color.new(color.gray, 92) : color.new(color.red,  85)
f_supBr(inv) =>
    (dimInvalidated and inv) ? color.new(color.gray, 70) : color.new(color.red,  25)
f_demBg(inv) =>
    (dimInvalidated and inv) ? color.new(color.gray, 92) : color.new(color.teal, 85)
f_demBr(inv) =>
    (dimInvalidated and inv) ? color.new(color.gray, 70) : color.new(color.teal, 25)

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATIONS — ATR, Session, OR
// BUG-12 FIX: single atrSig declaration here replaces both atrB and duplicate
// atrSig later. All bubble/body/signal code uses this one variable.
// ─────────────────────────────────────────────────────────────────────────────
float atrVal = ta.atr(14)                   // general-purpose ATR (zones, HTF, OR)
float atrSig = ta.atr(bubbleAtrLen)         // signal/bubble ATR (unified, no duplicate)
float tfMin  = tf_minutes()

bool inSess  = useSession ? not na(time(timeframe.period, sessionStr)) : true
// BUG-B FIX: ta.change() is history-dependent and cannot sit in a ternary
// false-branch that may not execute on every bar. Pre-compute both candidates
// unconditionally, then select between them with a plain bool ternary.
bool _newDay  = ta.change(time("D")) != 0          // BUG-B: always computed
bool _sessNew = inSess and not inSess[1]            // history ref [1] — also pre-computed
bool newSess  = useSession ? _sessNew : _newDay

// Session VWAP
var float cumPV = na
var float cumV  = na
if newSess or na(cumPV)
    cumPV := 0.0
    cumV  := 0.0
if inSess
    cumPV += hlc3 * volume
    cumV  += volume
float sessVwap = cumV > 0 ? (cumPV / cumV) : na
plot(showSessVWAP ? sessVwap : na, "Session VWAP", color=color.new(color.yellow, 0), linewidth=2)

// Opening Range
float orLenMin = orMode == "Auto" ? (orAutoK * tfMin) : float(orMin)
int   orBars   = math.max(1, int(math.ceil(orLenMin / math.max(tfMin, 1.0))))
var float orH     = na
var float orL     = na
var int   orCount = 0
if newSess
    orH     := na
    orL     := na
    orCount := 0
if inSess and orCount < orBars
    orH     := na(orH) ? high : math.max(orH, high)
    orL     := na(orL) ? low  : math.min(orL, low)
    orCount += 1
bool orReady = orCount >= orBars
plot(showOR and orReady ? orH : na, "OR High", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(showOR and orReady ? orL : na, "OR Low",  color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)

// ─────────────────────────────────────────────────────────────────────────────
// HTF TREND FILTER
// BUG-10 FIX: request.security() must not be inside a ternary — Pine v6 may
// skip the call on some bars, corrupting its internal history buffers.
// Solution: always call it; use nz() to fall back to current-TF value when
// useHTF is false. This is safe and produces zero overhead on confirmed bars.
// BUG-A FIX: adxCalc() contains ta.rma() which is history-dependent and cannot
// live in a ternary false-branch (may not execute every bar). Pre-compute on the
// current TF unconditionally, then select with a plain float ternary below.
// ─────────────────────────────────────────────────────────────────────────────
float _htfClose    = request.security(syminfo.tickerid, tfHTF, close[1],        barmerge.gaps_off, barmerge.lookahead_off)
float _htfAtr      = request.security(syminfo.tickerid, tfHTF, ta.atr(14),      barmerge.gaps_off, barmerge.lookahead_off)
float _htfAdx      = request.security(syminfo.tickerid, tfHTF, adxCalc(adxLen), barmerge.gaps_off, barmerge.lookahead_off)
float _curTFAdx    = adxCalc(adxLen)   // BUG-A: pre-computed unconditionally

// If useHTF is off, fall back to current-TF equivalents (plain float selects — no history calls in ternary)
float srcHTF  = useHTF ? _htfClose : close
float atrHTF  = useHTF ? _htfAtr   : atrVal
float adxHTF  = useHTF ? _htfAdx   : _curTFAdx

float emaF       = ta.ema(srcHTF, emaFastLen)
float emaS       = ta.ema(srcHTF, emaSlowLen)
bool  trendUp    = emaF > emaS
float emaDist    = math.abs(emaF - emaS)
bool  strongDist = emaDist > (atrHTF * distATRMin)

// BUG-01 FIX: multi-line ternaries → if/else if blocks
bool longOK  = false
bool shortOK = false
if trendMode == "Off"
    longOK  := true
    shortOK := true
else if trendMode == "EMA"
    longOK  := trendUp
    shortOK := not trendUp
else if trendMode == "EMA+ADX"
    longOK  := trendUp and adxHTF >= adxThr
    shortOK := (not trendUp) and adxHTF >= adxThr
else
    longOK  := trendUp and strongDist
    shortOK := (not trendUp) and strongDist

plot(plotHTFEMAs ? emaF : na, "HTF EMA Fast", color=color.new(color.teal,   0), linewidth=1)
plot(plotHTFEMAs ? emaS : na, "HTF EMA Slow", color=color.new(color.orange, 0), linewidth=1)

// BUG-07 FIX: bgCol nested ternary ending in : → if/else if block
color bgCol = na
if showCloud
    if longOK
        bgCol := color.new(color.rgb(0,180,120), 91)
    else if shortOK
        bgCol := color.new(color.rgb(200,50,50), 91)
bgcolor(bgCol, title="Trend Cloud")

// ─────────────────────────────────────────────────────────────────────────────
// ZONE FUNCTION
// ─────────────────────────────────────────────────────────────────────────────
f_zones(pL, pR, aLen, aMult) =>
    var float sup1T = na
    var float sup1B = na
    var float sup2T = na
    var float sup2B = na
    var float dem1T = na
    var float dem1B = na
    var float dem2T = na
    var float dem2B = na
    float atrZ = ta.atr(aLen)
    float ph   = ta.pivothigh(high, pL, pR)
    float pl   = ta.pivotlow(low,   pL, pR)
    if barstate.isconfirmed
        if not na(ph)
            sup2T := sup1T
            sup2B := sup1B
            sup1T := high[pR]
            sup1B := sup1T - atrZ[pR] * aMult
        if not na(pl)
            dem2T := dem1T
            dem2B := dem1B
            dem1B := low[pR]
            dem1T := dem1B + atrZ[pR] * aMult
    [sup1T, sup1B, sup2T, sup2B, dem1T, dem1B, dem2T, dem2B]

[s1T_1, s1B_1, s2T_1, s2B_1, d1T_1, d1B_1, d2T_1, d2B_1] =
     request.security(syminfo.tickerid, tf1, f_zones(pivotL, pivotR, zoneAtrLen, zoneAtrMult),
          barmerge.gaps_off, barmerge.lookahead_off)

[s1T_2, s1B_2, s2T_2, s2B_2, d1T_2, d1B_2, d2T_2, d2B_2] =
     request.security(syminfo.tickerid, tf2, f_zones(pivotL, pivotR, zoneAtrLen, zoneAtrMult),
          barmerge.gaps_off, barmerge.lookahead_off)

[s1T_3, s1B_3, s2T_3, s2B_3, d1T_3, d1B_3, d2T_3, d2B_3] =
     request.security(syminfo.tickerid, tf3, f_zones(pivotL, pivotR, zoneAtrLen, zoneAtrMult),
          barmerge.gaps_off, barmerge.lookahead_off)

// ─────────────────────────────────────────────────────────────────────────────
// ZONE CHANGE DETECTION
// ─────────────────────────────────────────────────────────────────────────────
f_zoneNew(cur, prev) =>
    not na(cur) and (na(prev) or cur != prev)

new_tf1_sup  = f_zoneNew(s1T_1, s1T_1[1])
new_tf1_supT = f_zoneNew(s2T_1, s2T_1[1])
new_tf1_dem  = f_zoneNew(d1T_1, d1T_1[1])
new_tf1_demT = f_zoneNew(d2T_1, d2T_1[1])
new_tf2_sup  = f_zoneNew(s1T_2, s1T_2[1])
new_tf2_supT = f_zoneNew(s2T_2, s2T_2[1])
new_tf2_dem  = f_zoneNew(d1T_2, d1T_2[1])
new_tf2_demT = f_zoneNew(d2T_2, d2T_2[1])
new_tf3_sup  = f_zoneNew(s1T_3, s1T_3[1])
new_tf3_supT = f_zoneNew(s2T_3, s2T_3[1])
new_tf3_dem  = f_zoneNew(d1T_3, d1T_3[1])
new_tf3_demT = f_zoneNew(d2T_3, d2T_3[1])

// ─────────────────────────────────────────────────────────────────────────────
// ZONE INVALIDATION
// ─────────────────────────────────────────────────────────────────────────────
var bool sup1_inv_1 = false
var bool dem1_inv_1 = false
var bool sup1_inv_2 = false
var bool dem1_inv_2 = false
var bool sup1_inv_3 = false
var bool dem1_inv_3 = false

if new_tf1_sup
    sup1_inv_1 := false
if new_tf1_dem
    dem1_inv_1 := false
if new_tf2_sup
    sup1_inv_2 := false
if new_tf2_dem
    dem1_inv_2 := false
if new_tf3_sup
    sup1_inv_3 := false
if new_tf3_dem
    dem1_inv_3 := false

if barstate.isconfirmed
    if not na(s1T_1) and close > math.max(s1T_1, s1B_1) + pad
        sup1_inv_1 := true
    if not na(d1B_1) and close < math.min(d1T_1, d1B_1) - pad
        dem1_inv_1 := true
    if not na(s1T_2) and close > math.max(s1T_2, s1B_2) + pad
        sup1_inv_2 := true
    if not na(d1B_2) and close < math.min(d1T_2, d1B_2) - pad
        dem1_inv_2 := true
    if not na(s1T_3) and close > math.max(s1T_3, s1B_3) + pad
        sup1_inv_3 := true
    if not na(d1B_3) and close < math.min(d1T_3, d1B_3) - pad
        dem1_inv_3 := true

color supBgT = color.new(color.red,  92)
color supBrT = color.new(color.red,  50)
color demBgT = color.new(color.teal, 92)
color demBrT = color.new(color.teal, 50)

// ─────────────────────────────────────────────────────────────────────────────
// OPERATOR CANDLES
// BUG-08 FIX: barcolor() nested ternary ending on : → explicit if/else if
// ─────────────────────────────────────────────────────────────────────────────
float volSma  = ta.sma(volume, opVolLen)
bool  isBuyOp  = (close > open) and (volume > volSma * opVolMult)
bool  isSellOp = (close < open) and (volume > volSma * opVolMult)

color barCol = na
if paintOperatorCandles
    if isBuyOp
        barCol := color.new(color.blue,  0)
    else if isSellOp
        barCol := color.new(color.black, 0)
barcolor(barCol)

// ─────────────────────────────────────────────────────────────────────────────
// VOLUME DELTA + BUBBLES
// BUG-12 FIX: atrB removed — atrSig (declared above) is used throughout
// ─────────────────────────────────────────────────────────────────────────────
float bodyB  = math.abs(close - open)
float rng2   = math.max(high - low, syminfo.mintick)
float dRW    = rng2 > 0 ? volume * (close - open) / rng2 : 0.0
float dCP    = close >= close[1] ? volume : -volume
float dCO    = close >= open     ? volume : -volume
float delta  = deltaMode == "RangeWeighted" ? dRW : deltaMode == "CloseVsOpen" ? dCO : dCP
float absDel = math.abs(delta)

bool bubbleBase = (volume > volSma * bubbleVolMult) and (bodyB > atrSig * bubbleAtrMult)

bool touchTF1 = useTF1 and (f_touchZone(s1T_1, s1B_1) or f_touchZone(d1T_1, d1B_1) or
                (showTargets and (f_touchZone(s2T_1, s2B_1) or f_touchZone(d2T_1, d2B_1))))
bool touchTF2 = useTF2 and (f_touchZone(s1T_2, s1B_2) or f_touchZone(d1T_2, d1B_2) or
                (showTargets and (f_touchZone(s2T_2, s2B_2) or f_touchZone(d2T_2, d2B_2))))
bool touchTF3 = useTF3 and (f_touchZone(s1T_3, s1B_3) or f_touchZone(d1T_3, d1B_3) or
                (showTargets and (f_touchZone(s2T_3, s2B_3) or f_touchZone(d2T_3, d2B_3))))
bool touchAny = touchTF1 or touchTF2 or touchTF3

bool bubbleOk = showBubbles and bubbleBase and (not bubbleOnlyInZone or touchAny)
plotshape(bubbleOk and close > open, title="Buy Bubble",  style=shape.circle, size=size.small, location=location.belowbar, color=color.new(color.green, 55))
plotshape(bubbleOk and close < open, title="Sell Bubble", style=shape.circle, size=size.small, location=location.abovebar, color=color.new(color.red,   55))

// ─────────────────────────────────────────────────────────────────────────────
// CONFLUENT ZONE HIGHLIGHT
// ─────────────────────────────────────────────────────────────────────────────
bool inSupTF1 = useTF1 and f_touchZone(s1T_1, s1B_1)
bool inSupTF2 = useTF2 and f_touchZone(s1T_2, s1B_2)
bool inSupTF3 = useTF3 and f_touchZone(s1T_3, s1B_3)
bool inDemTF1 = useTF1 and f_touchZone(d1T_1, d1B_1)
bool inDemTF2 = useTF2 and f_touchZone(d1T_2, d1B_2)
bool inDemTF3 = useTF3 and f_touchZone(d1T_3, d1B_3)

bool supConfluence = (int(inSupTF1 ? 1 : 0) + int(inSupTF2 ? 1 : 0) + int(inSupTF3 ? 1 : 0)) >= 2
bool demConfluence = (int(inDemTF1 ? 1 : 0) + int(inDemTF2 ? 1 : 0) + int(inDemTF3 ? 1 : 0)) >= 2
bgcolor(showConfluentHL and supConfluence ? color.new(color.red,  88) : na, title="Confluent Supply BG")
bgcolor(showConfluentHL and demConfluence ? color.new(color.teal, 88) : na, title="Confluent Demand BG")

// ─────────────────────────────────────────────────────────────────────────────
// RSI OB/OS BACKGROUND
// ─────────────────────────────────────────────────────────────────────────────
float rsi = ta.rsi(close, rsiLen)
bgcolor(showRSIBg and rsi >= rsiOB ? color.new(color.red,   93) : na, title="RSI OB BG")
bgcolor(showRSIBg and rsi <= rsiOS ? color.new(color.green, 93) : na, title="RSI OS BG")

// ─────────────────────────────────────────────────────────────────────────────
// DRAW ZONES — anchored left edges
// BUG-05 FIX: every var declaration is on its own line (no comma-chaining)
// ─────────────────────────────────────────────────────────────────────────────
var box tf1_sup  = na
var box tf1_supT = na
var box tf1_dem  = na
var box tf1_demT = na
var box tf2_sup  = na
var box tf2_supT = na
var box tf2_dem  = na
var box tf2_demT = na
var box tf3_sup  = na
var box tf3_supT = na
var box tf3_dem  = na
var box tf3_demT = na

var int tf1_sup_left  = na
var int tf1_supT_left = na
var int tf1_dem_left  = na
var int tf1_demT_left = na
var int tf2_sup_left  = na
var int tf2_supT_left = na
var int tf2_dem_left  = na
var int tf2_demT_left = na
var int tf3_sup_left  = na
var int tf3_supT_left = na
var int tf3_dem_left  = na
var int tf3_demT_left = na

var line tf1_sup_mid = na
var line tf1_dem_mid = na
var line tf2_sup_mid = na
var line tf2_dem_mid = na
var line tf3_sup_mid = na
var line tf3_dem_mid = na

var label l1s_lbl = na
var label l1d_lbl = na
var label l2s_lbl = na
var label l2d_lbl = na
var label l3s_lbl = na
var label l3d_lbl = na

if useTF1
    if na(tf1_sup_left) or new_tf1_sup
        tf1_sup_left := f_safeLeft(bar_index)
    if na(tf1_dem_left) or new_tf1_dem
        tf1_dem_left := f_safeLeft(bar_index)
    if showTargets
        if na(tf1_supT_left) or new_tf1_supT
            tf1_supT_left := f_safeLeft(bar_index)
        if na(tf1_demT_left) or new_tf1_demT
            tf1_demT_left := f_safeLeft(bar_index)

if useTF2
    if na(tf2_sup_left) or new_tf2_sup
        tf2_sup_left := f_safeLeft(bar_index)
    if na(tf2_dem_left) or new_tf2_dem
        tf2_dem_left := f_safeLeft(bar_index)
    if showTargets
        if na(tf2_supT_left) or new_tf2_supT
            tf2_supT_left := f_safeLeft(bar_index)
        if na(tf2_demT_left) or new_tf2_demT
            tf2_demT_left := f_safeLeft(bar_index)

if useTF3
    if na(tf3_sup_left) or new_tf3_sup
        tf3_sup_left := f_safeLeft(bar_index)
    if na(tf3_dem_left) or new_tf3_dem
        tf3_dem_left := f_safeLeft(bar_index)
    if showTargets
        if na(tf3_supT_left) or new_tf3_supT
            tf3_supT_left := f_safeLeft(bar_index)
        if na(tf3_demT_left) or new_tf3_demT
            tf3_demT_left := f_safeLeft(bar_index)

bool anyChange = new_tf1_sup or new_tf1_dem or new_tf1_supT or new_tf1_demT or
                 new_tf2_sup or new_tf2_dem or new_tf2_supT or new_tf2_demT or
                 new_tf3_sup or new_tf3_dem or new_tf3_supT or new_tf3_demT

if barstate.islast or anyChange
    int l1s  = f_liveLeft(tf1_sup_left)
    int l1d  = f_liveLeft(tf1_dem_left)
    int l1sT = f_liveLeft(tf1_supT_left)
    int l1dT = f_liveLeft(tf1_demT_left)
    int l2s  = f_liveLeft(tf2_sup_left)
    int l2d  = f_liveLeft(tf2_dem_left)
    int l2sT = f_liveLeft(tf2_supT_left)
    int l2dT = f_liveLeft(tf2_demT_left)
    int l3s  = f_liveLeft(tf3_sup_left)
    int l3d  = f_liveLeft(tf3_dem_left)
    int l3sT = f_liveLeft(tf3_supT_left)
    int l3dT = f_liveLeft(tf3_demT_left)

    tf1_sup  := f_box_update(tf1_sup,  useTF1,                 l1s,  s1T_1, s1B_1, f_supBg(sup1_inv_1), f_supBr(sup1_inv_1))
    tf1_dem  := f_box_update(tf1_dem,  useTF1,                 l1d,  d1T_1, d1B_1, f_demBg(dem1_inv_1), f_demBr(dem1_inv_1))
    tf1_supT := f_box_update(tf1_supT, useTF1 and showTargets, l1sT, s2T_1, s2B_1, supBgT, supBrT)
    tf1_demT := f_box_update(tf1_demT, useTF1 and showTargets, l1dT, d2T_1, d2B_1, demBgT, demBrT)
    tf2_sup  := f_box_update(tf2_sup,  useTF2,                 l2s,  s1T_2, s1B_2, f_supBg(sup1_inv_2), f_supBr(sup1_inv_2))
    tf2_dem  := f_box_update(tf2_dem,  useTF2,                 l2d,  d1T_2, d1B_2, f_demBg(dem1_inv_2), f_demBr(dem1_inv_2))
    tf2_supT := f_box_update(tf2_supT, useTF2 and showTargets, l2sT, s2T_2, s2B_2, supBgT, supBrT)
    tf2_demT := f_box_update(tf2_demT, useTF2 and showTargets, l2dT, d2T_2, d2B_2, demBgT, demBrT)
    tf3_sup  := f_box_update(tf3_sup,  useTF3,                 l3s,  s1T_3, s1B_3, f_supBg(sup1_inv_3), f_supBr(sup1_inv_3))
    tf3_dem  := f_box_update(tf3_dem,  useTF3,                 l3d,  d1T_3, d1B_3, f_demBg(dem1_inv_3), f_demBr(dem1_inv_3))
    tf3_supT := f_box_update(tf3_supT, useTF3 and showTargets, l3sT, s2T_3, s2B_3, supBgT, supBrT)
    tf3_demT := f_box_update(tf3_demT, useTF3 and showTargets, l3dT, d2T_3, d2B_3, demBgT, demBrT)

    color midCol = color.new(color.gray, 50)
    if useTF1 and showZoneMid
        if not na(s1T_1) and not na(s1B_1)
            float mS1 = (math.max(s1T_1, s1B_1) + math.min(s1T_1, s1B_1)) * 0.5
            if na(tf1_sup_mid)
                tf1_sup_mid := line.new(l1s, mS1, bar_index + extendRightBars, mS1, color=midCol, style=line.style_dashed, width=1)
            else
                line.set_x1(tf1_sup_mid, l1s)
                line.set_x2(tf1_sup_mid, bar_index + extendRightBars)
                line.set_y1(tf1_sup_mid, mS1)
                line.set_y2(tf1_sup_mid, mS1)
        if not na(d1T_1) and not na(d1B_1)
            float mD1 = (math.max(d1T_1, d1B_1) + math.min(d1T_1, d1B_1)) * 0.5
            if na(tf1_dem_mid)
                tf1_dem_mid := line.new(l1d, mD1, bar_index + extendRightBars, mD1, color=midCol, style=line.style_dashed, width=1)
            else
                line.set_x1(tf1_dem_mid, l1d)
                line.set_x2(tf1_dem_mid, bar_index + extendRightBars)
                line.set_y1(tf1_dem_mid, mD1)
                line.set_y2(tf1_dem_mid, mD1)
    if useTF2 and showZoneMid
        if not na(s1T_2) and not na(s1B_2)
            float mS2 = (math.max(s1T_2, s1B_2) + math.min(s1T_2, s1B_2)) * 0.5
            if na(tf2_sup_mid)
                tf2_sup_mid := line.new(l2s, mS2, bar_index + extendRightBars, mS2, color=midCol, style=line.style_dashed, width=1)
            else
                line.set_x1(tf2_sup_mid, l2s)
                line.set_x2(tf2_sup_mid, bar_index + extendRightBars)
                line.set_y1(tf2_sup_mid, mS2)
                line.set_y2(tf2_sup_mid, mS2)
        if not na(d1T_2) and not na(d1B_2)
            float mD2 = (math.max(d1T_2, d1B_2) + math.min(d1T_2, d1B_2)) * 0.5
            if na(tf2_dem_mid)
                tf2_dem_mid := line.new(l2d, mD2, bar_index + extendRightBars, mD2, color=midCol, style=line.style_dashed, width=1)
            else
                line.set_x1(tf2_dem_mid, l2d)
                line.set_x2(tf2_dem_mid, bar_index + extendRightBars)
                line.set_y1(tf2_dem_mid, mD2)
                line.set_y2(tf2_dem_mid, mD2)

    l1s_lbl := f_label_update(l1s_lbl, useTF1 and showZoneLabels, s1T_1, tf1 + " Supply", color.new(color.red,  0))
    l1d_lbl := f_label_update(l1d_lbl, useTF1 and showZoneLabels, d1B_1, tf1 + " Demand", color.new(color.teal, 0))
    l2s_lbl := f_label_update(l2s_lbl, useTF2 and showZoneLabels, s1T_2, tf2 + " Supply", color.new(color.red,  0))
    l2d_lbl := f_label_update(l2d_lbl, useTF2 and showZoneLabels, d1B_2, tf2 + " Demand", color.new(color.teal, 0))
    l3s_lbl := f_label_update(l3s_lbl, useTF3 and showZoneLabels, s1T_3, tf3 + " Supply", color.new(color.red,  0))
    l3d_lbl := f_label_update(l3d_lbl, useTF3 and showZoneLabels, d1B_3, tf3 + " Demand", color.new(color.teal, 0))

// ─────────────────────────────────────────────────────────────────────────────
// OVERLAYS — MVWAP + MAs
// BUG-03 FIX: ta.crossover/crossunder pre-computed unconditionally
// BUG-11 FIX: entryEma later reuses ma1 — no second ta.ema() call needed
// ─────────────────────────────────────────────────────────────────────────────
float mvwap = f_ma(sessVwap, mvwapLen, mvwapType)
plot(showMVWAP ? mvwap : na, title="MVWAP", color=color.new(color.orange, 50), linewidth=2)

float ma1 = f_ma(close, ma1Len, ma1Type)
float ma2 = f_ma(close, ma2Len, ma2Type)
float ma3 = f_ma(close, ma3Len, ma3Type)

plot(showMA1 ? ma1 : na, title="MA1", color=color.new(color.aqua,  0), linewidth=2)
plot(showMA2 ? ma2 : na, title="MA2", color=color.new(color.white, 0), linewidth=2)
plot(showMA3 ? ma3 : na, title="MA3", color=color.new(color.gray,  0), linewidth=2)

// BUG-03 FIX: always computed at global scope — no short-circuit risk
bool crossBullRaw = ta.crossover(ma1,  ma2)
bool crossBearRaw = ta.crossunder(ma1, ma2)
bool maCrossBull  = showMACross and showMA1 and showMA2 and crossBullRaw
bool maCrossBear  = showMACross and showMA1 and showMA2 and crossBearRaw
plotshape(maCrossBull, title="MA Cross Bull", style=shape.triangleup,   location=location.belowbar, size=size.tiny, color=color.new(color.aqua,  0))
plotshape(maCrossBear, title="MA Cross Bear", style=shape.triangledown, location=location.abovebar, size=size.tiny, color=color.new(color.white, 0))

// ─────────────────────────────────────────────────────────────────────────────
// OVERLAYS — HTF MA
// ─────────────────────────────────────────────────────────────────────────────
f_htf_ma() =>
    float m = f_ma(close, htfMA_len, htfMA_type)
    htfConfirmedOnly ? m[1] : m

float htfMA = request.security(syminfo.tickerid, htfMA_tf, f_htf_ma(), barmerge.gaps_off, barmerge.lookahead_off)
plot(showHTFMA ? htfMA : na, title="HTF MA", color=color.new(color.purple, 0), linewidth=2)

// ─────────────────────────────────────────────────────────────────────────────
// OVERLAYS — Bollinger Bands + fill
// ─────────────────────────────────────────────────────────────────────────────
[bbBasis, bbUpper, bbLower] = ta.bb(close, bbLen, bbMult)
pBBU = plot(showBB ? bbUpper : na, title="BB Upper", color=color.new(color.blue, 50))
pBBM = plot(showBB ? bbBasis : na, title="BB Basis", color=color.new(color.blue, 30))
pBBL = plot(showBB ? bbLower : na, title="BB Lower", color=color.new(color.blue, 50))
fill(pBBU, pBBL, color=(showBB and showBBFill) ? color.new(color.blue, 93) : na, title="BB Fill")

// ─────────────────────────────────────────────────────────────────────────────
// OVERLAYS — Supertrend (direction-coloured)
// ─────────────────────────────────────────────────────────────────────────────
[st1, st1Dir] = ta.supertrend(st1Mult, st1Atr)
[st2, st2Dir] = ta.supertrend(st2Mult, st2Atr)
color st1Col = st1Dir == -1 ? color.new(color.green, 0) : color.new(color.red, 0)
color st2Col = st2Dir == -1 ? color.new(color.green, 0) : color.new(color.red, 0)
plot(showST1 ? st1 : na, title="Supertrend 1", color=st1Col, linewidth=2)
plot(showST2 ? st2 : na, title="Supertrend 2", color=st2Col, linewidth=2)

// ─────────────────────────────────────────────────────────────────────────────
// OVERLAYS — RSI label
// BUG-09 FIX: rCol multi-line ternary inside if block → if/else if block
// ─────────────────────────────────────────────────────────────────────────────
var label rsiLbl = na
if showRSILast and barstate.islast
    int    rx   = bar_index + labelOffsetBars
    color  rCol = na
    if rsi >= rsiOB
        rCol := color.new(color.red,   0)
    else if rsi <= rsiOS
        rCol := color.new(color.green, 0)
    else
        rCol := color.new(color.gray,  0)
    string rtxt = "RSI " + str.tostring(int(rsi))
    if na(rsiLbl)
        rsiLbl := label.new(rx, close, rtxt, style=label.style_label_center, size=size.large, textcolor=color.white, color=rCol)
    else
        label.set_xy(rsiLbl, rx, close)
        label.set_text(rsiLbl, rtxt)
        label.set_color(rsiLbl, rCol)

// ─────────────────────────────────────────────────────────────────────────────
// DENSITY BOXES
// ─────────────────────────────────────────────────────────────────────────────
float denMetric = denMetricSrc == "AbsDelta" ? absDel : volume
float denThr    = ta.percentile_linear_interpolation(denMetric, qLen, qPct)
float volMA     = ta.sma(volume, volLen)

var box[]   dBoxes = array.new_box()
var line[]  dLines = array.new_line()
var float[] dTop   = array.new_float()
var float[] dBot   = array.new_float()
var float[] dMid   = array.new_float()
var int[]   dEnd   = array.new_int()
var int[]   dDir   = array.new_int()

newDensity(_mid, _isDemand) =>
    float half    = atrVal * denDepth
    float dtop    = _mid + half
    float dbot    = _mid - half
    color fillCol = _isDemand ? color.new(#4CAF50, 90) : color.new(#F44336, 90)
    color brdCol  = _isDemand ? color.new(#4CAF50, 60) : color.new(#F44336, 60)
    if array.size(dBoxes) >= maxDenBoxes
        box  ob = array.shift(dBoxes)
        line ol = array.shift(dLines)
        array.shift(dTop), array.shift(dBot), array.shift(dMid)
        array.shift(dEnd), array.shift(dDir)
        if not na(ob)
            box.delete(ob)
        if not na(ol)
            line.delete(ol)
    box  b  = box.new(bar_index, dtop, bar_index, dbot, xloc=xloc.bar_index, bgcolor=fillCol, border_color=brdCol)
    line ln = line.new(bar_index, _mid, bar_index, _mid, xloc=xloc.bar_index,
                       extend=extend.right, color=color.new(color.gray, 50), style=line.style_dashed, width=1)
    array.push(dBoxes, b),  array.push(dLines, ln)
    array.push(dTop, dtop), array.push(dBot, dbot), array.push(dMid, _mid)
    array.push(dEnd, bar_index + denExtend), array.push(dDir, _isDemand ? 1 : -1)

if activityMode == "Densities" and inSess and denMetric >= denThr and barstate.isconfirmed
    float midp  = close
    bool  merged = false
    int   sz     = array.size(dBoxes)
    if sz > 0
        for i = 0 to sz - 1
            if not merged and math.abs(midp - array.get(dMid, i)) <= atrVal * mergeX
                array.set(dEnd, i, bar_index + denExtend)
                merged := true
    if not merged
        newDensity(midp, delta >= 0)

int sz2 = array.size(dBoxes)
if sz2 > 0
    for i = sz2 - 1 to 0
        box   db   = array.get(dBoxes, i)
        line  dl   = array.get(dLines, i)
        float dtop = array.get(dTop, i)
        float dbot = array.get(dBot, i)
        float midp = array.get(dMid, i)
        int   rgt  = math.min(bar_index + 1, array.get(dEnd, i))
        box.set_right(db, rgt)
        line.set_x2(dl, rgt)
        line.set_y1(dl, midp)
        line.set_y2(dl, midp)
        int  dir       = array.get(dDir, i)
        bool breakUp   = close > dtop and volume > volMA * breakMult
        bool breakDown = close < dbot and volume > volMA * breakMult
        bool eaten     = (dir == 1 and breakDown) or (dir == -1 and breakUp)
        if eaten or bar_index >= array.get(dEnd, i)
            box.delete(db), line.delete(dl)
            array.remove(dBoxes, i), array.remove(dLines, i)
            array.remove(dTop, i),   array.remove(dBot, i)
            array.remove(dMid, i),   array.remove(dEnd, i), array.remove(dDir, i)

// ─────────────────────────────────────────────────────────────────────────────
// SCALPING SIGNALS
// ─────────────────────────────────────────────────────────────────────────────
float bodySize  = math.abs(close - open)
float rng3      = math.max(high - low, syminfo.mintick)
float upperWick = high - math.max(open, close)
float lowerWick = math.min(open, close) - low
bool  validBody     = bodySize > (atrSig * minBodyATR)
bool  validWickBull = rng3 > 0 ? (upperWick / rng3 <= wickMaxPct) : true
bool  validWickBear = rng3 > 0 ? (lowerWick / rng3 <= wickMaxPct) : true

bool vwapBullOK  = (not gateVWAP) or (not na(sessVwap) and close >= sessVwap)
bool vwapBearOK  = (not gateVWAP) or (not na(sessVwap) and close <= sessVwap)
bool trendBullOK = (not gateTrend) or longOK
bool trendBearOK = (not gateTrend) or shortOK

bool trapSellRaw = f_anyTF3(useTF1, useTF2, useTF3,
                    f_trapSell(s1T_1, s1B_1, volSma),
                    f_trapSell(s1T_2, s1B_2, volSma),
                    f_trapSell(s1T_3, s1B_3, volSma))
bool trapBuyRaw  = f_anyTF3(useTF1, useTF2, useTF3,
                    f_trapBuy(d1T_1, d1B_1, volSma),
                    f_trapBuy(d1T_2, d1B_2, volSma),
                    f_trapBuy(d1T_3, d1B_3, volSma))
bool lvtBuyRaw   = f_anyTF3(useTF1, useTF2, useTF3,
                    f_lvtBuy(d1T_1, d1B_1, volSma, atrSig),
                    f_lvtBuy(d1T_2, d1B_2, volSma, atrSig),
                    f_lvtBuy(d1T_3, d1B_3, volSma, atrSig))
bool lvtSellRaw  = f_anyTF3(useTF1, useTF2, useTF3,
                    f_lvtSell(s1T_1, s1B_1, volSma, atrSig),
                    f_lvtSell(s1T_2, s1B_2, volSma, atrSig),
                    f_lvtSell(s1T_3, s1B_3, volSma, atrSig))

bool buySetup  = showSignals and (trapBuyRaw  or lvtBuyRaw)  and validBody and validWickBull and vwapBullOK and trendBullOK
bool sellSetup = showSignals and (trapSellRaw or lvtSellRaw) and validBody and validWickBear and vwapBearOK and trendBearOK

var int  lastBuyBar    = -9999
var int  lastSellBar   = -9999
var bool buyMovedAway  = false
var bool sellMovedAway = false
var bool buyEligible   = true
var bool sellEligible  = true

// BUG-11 FIX: entryEma reuses ma1 — no duplicate ta.ema() call
// Note: if ma1Type != EMA the EMA character is lost, but this is intentional —
// the entry EMA reference line follows the user's chosen MA1 type.
float entryEma = ma1

if lastBuyBar > -9999
    if close >= entryEma + atrSig * resetMoveATR
        buyMovedAway := true
    if buyMovedAway and low <= entryEma
        buyEligible := true

if lastSellBar > -9999
    if close <= entryEma - atrSig * resetMoveATR
        sellMovedAway := true
    if sellMovedAway and high >= entryEma
        sellEligible := true

bool coolBuyOK  = bar_index - lastBuyBar  >= sigCooldownBars
bool coolSellOK = bar_index - lastSellBar >= sigCooldownBars

// BUG-02 FIX: multi-line ternary → if/else if blocks
bool buyReOK  = false
bool sellReOK = false
if reMode == "Cooldown"
    buyReOK  := coolBuyOK
    sellReOK := coolSellOK
else if reMode == "MoveAway+Retest"
    buyReOK  := buyEligible
    sellReOK := sellEligible
else
    buyReOK  := coolBuyOK  or buyEligible
    sellReOK := coolSellOK or sellEligible

bool buySignal  = buySetup  and buyReOK
bool sellSignal = sellSetup and sellReOK

if buySignal
    lastBuyBar    := bar_index
    buyMovedAway  := false
    buyEligible   := false
if sellSignal
    lastSellBar   := bar_index
    sellMovedAway := false
    sellEligible  := false

bool isTrapBuy  = trapBuyRaw  and buySignal
bool isLvtBuy   = lvtBuyRaw   and buySignal  and not trapBuyRaw
bool isTrapSell = trapSellRaw and sellSignal
bool isLvtSell  = lvtSellRaw  and sellSignal and not trapSellRaw

var label buySigInfoLbl = na
var label sellSigInfoLbl = na

color bullDirCol = color.rgb(0, 180, 120)
color bearDirCol = color.rgb(200, 50, 50)
plotshape(showDirLabels and buySignal,  title="LONG Label",  style=shape.labelup,   location=location.belowbar, text="LONG",  size=size.normal, color=bullDirCol, textcolor=color.white)
plotshape(showDirLabels and sellSignal, title="SHORT Label", style=shape.labeldown, location=location.abovebar, text="SHORT", size=size.normal, color=bearDirCol, textcolor=color.white)

plotshape(isTrapSell, title="TRP1 Sell", style=shape.labeldown,    location=location.abovebar, text="TRP1", size=size.tiny, color=color.new(color.red,   0), textcolor=color.white)
plotshape(isTrapBuy,  title="TRP1 Buy",  style=shape.labelup,      location=location.belowbar, text="TRP1", size=size.tiny, color=color.new(color.green, 0), textcolor=color.white)
plotshape(isLvtBuy,   title="LVT Buy",   style=shape.triangleup,   location=location.belowbar, text="LVT",  size=size.tiny, color=color.new(color.green, 0), textcolor=color.white)
plotshape(isLvtSell,  title="LVT Sell",  style=shape.triangledown, location=location.abovebar, text="LVT",  size=size.tiny, color=color.new(color.red,   0), textcolor=color.white)

if showSigLabels
    int decPlaces = syminfo.mintick >= 1 ? 0 : 2
    if buySignal
        float sl  = low   - atrSig * sigStopMult
        float tp1 = close + atrSig * sigTarget1Mult
        float tp2 = close + atrSig * sigTarget2Mult
        float rr1 = math.round((tp1 - close) / math.max(close - sl, syminfo.mintick), 2)
        if keepLatestSigLabel and not na(buySigInfoLbl)
            label.delete(buySigInfoLbl)
        buySigInfoLbl := label.new(bar_index, low - atrSig * 0.4,
                  "SL "   + str.tostring(math.round(sl,  decPlaces)) +
                  "\nTP1 " + str.tostring(math.round(tp1, decPlaces)) +
                  "\nTP2 " + str.tostring(math.round(tp2, decPlaces)) +
                  "\nRR "  + str.tostring(rr1) + "R",
                  style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, size=size.small)
    if sellSignal
        float sl  = high  + atrSig * sigStopMult
        float tp1 = close - atrSig * sigTarget1Mult
        float tp2 = close - atrSig * sigTarget2Mult
        float rr1 = math.round((close - tp1) / math.max(sl - close, syminfo.mintick), 2)
        if keepLatestSigLabel and not na(sellSigInfoLbl)
            label.delete(sellSigInfoLbl)
        sellSigInfoLbl := label.new(bar_index, high + atrSig * 0.4,
                  "SL "   + str.tostring(math.round(sl,  decPlaces)) +
                  "\nTP1 " + str.tostring(math.round(tp1, decPlaces)) +
                  "\nTP2 " + str.tostring(math.round(tp2, decPlaces)) +
                  "\nRR "  + str.tostring(rr1) + "R",
                  style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// BUG-04 FIX: all ta.crossover/crossunder pre-computed unconditionally
// ─────────────────────────────────────────────────────────────────────────────
bool orBreakUp   = ta.crossover(close,  orH)
bool orBreakDown = ta.crossunder(close, orL)
bool vwapCrossUp = ta.crossover(close,  sessVwap)
bool vwapCrossDn = ta.crossunder(close, sessVwap)

alertcondition(isTrapBuy,                     title="TRP1 Buy",          message="TRP1 Buy — {{ticker}} {{interval}}")
alertcondition(isTrapSell,                    title="TRP1 Sell",         message="TRP1 Sell — {{ticker}} {{interval}}")
alertcondition(isLvtBuy,                      title="LVT Buy",           message="LVT Buy — {{ticker}} {{interval}}")
alertcondition(isLvtSell,                     title="LVT Sell",          message="LVT Sell — {{ticker}} {{interval}}")
alertcondition(maCrossBull,                   title="MA Cross Bull",     message="MA Bullish Cross — {{ticker}} {{interval}}")
alertcondition(maCrossBear,                   title="MA Cross Bear",     message="MA Bearish Cross — {{ticker}} {{interval}}")
alertcondition(supConfluence,                 title="Supply Confluence", message="Multi-TF Supply Confluence — {{ticker}}")
alertcondition(demConfluence,                 title="Demand Confluence", message="Multi-TF Demand Confluence — {{ticker}}")
alertcondition(orReady and orBreakUp,         title="OR Break Up",       message="OR High Break — {{ticker}} {{interval}}")
alertcondition(orReady and orBreakDown,       title="OR Break Down",     message="OR Low Break — {{ticker}} {{interval}}")
alertcondition(showSessVWAP and vwapCrossUp,  title="VWAP Cross Up",     message="Cross Above Session VWAP — {{ticker}}")
alertcondition(showSessVWAP and vwapCrossDn,  title="VWAP Cross Down",   message="Cross Below Session VWAP — {{ticker}}")
